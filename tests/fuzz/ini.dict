# AFL++ dictionary for INI / client.conf parser (openQAclient)
# Each entry is a token the mutator will splice into inputs.
# Structural tokens
"["
"]"
"["
"="
"#"
";"
"\n"
"\r\n"

# Well-known section names
"openqa.suse.de"
"openqa.opensuse.org"
"localhost"
"127.0.0.1"

# Well-known key names
"key"
"secret"

# Values: realistic lengths and character classes
"PUBLICKEY12345678"
"SECRETKEY12345678"
"A"
""

# Whitespace variants around delimiters
" = "
"= "
" ="

# Comment prefixes
"# "
"; "

# Malformed / boundary section headers
"[]"
"[ ]"
"[openqa.suse.de"
"openqa.suse.de]"
"[[openqa.suse.de]]"
