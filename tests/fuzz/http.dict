# AFL++ token dictionary for the HTTP response parsers.
# Covers RFC 5988 Link header syntax and common JSON tokens.

# Link header keywords
"rel="
"rel=\"next\""
"rel=\"prev\""
"rel=\"first\""
"rel=\"last\""
"; "
", "

# JSON structural tokens
"{"
"}"
"["
"]"
"null"
"true"
"false"

# Common JSON field names in openQA responses
"\"id\""
"\"state\""
"\"result\""
"\"name\""
"\"jobs\""
"\"job\""
"\"settings\""
"\"passed\""
"\"failed\""
"\"running\""
"\"done\""
"\"scheduled\""
"\"softfailed\""
